{
  "name": "melody4u-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "start:lan": "expo start --clear --lan",
    "start:localhost": "expo start --clear --localhost",
    "start:tunnel": "expo start --clear --tunnel",
    "android": "expo run:android",
    "android:go": "expo start --android",
    "ios": "expo start --ios",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-av": "~15.1.7",
    "expo-constants": "~17.1.8",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.11",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  }
}
